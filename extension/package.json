{
  "name": "viewgraph-capture",
  "version": "0.9.8",
  "description": "Browser extension for capturing DOM structure, screenshots, and annotations for AI-powered UI analysis  -  ViewGraph",
  "type": "module",
  "imports": {
    "#lib/*.js": "./lib/*.js",
    "#lib/*": "./lib/*",
    "#tests/*.js": "./tests/*.js",
    "#tests/*": "./tests/*"
  },
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "license": "AGPL-3.0",
  "devDependencies": {
    "jsdom": "^29.0.2",
    "vitest": "^4.1.3",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "axe-core": "^4.11.2",
    "jszip": "^3.10.1"
  },
  "optionalDependencies": {
    "@vitest/coverage-v8": "^4.1.4"
  }
}
