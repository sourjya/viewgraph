{
  "name": "sifr-capture",
  "version": "0.1.0",
  "description": "Browser extension for capturing DOM structure, screenshots, and annotations for AI-powered UI analysis",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
