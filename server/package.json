{
  "name": "viewgraph-mcp-server",
  "version": "0.9.8",
  "description": "MCP server exposing ViewGraph capture tools to AI coding assistants",
  "type": "module",
  "main": "index.js",
  "imports": {
    "#src/*.js": "./src/*.js",
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "node index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.js",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chokidar": "5.0.0",
    "fast-json-patch": "3.1.1",
    "pixelmatch": "7.1.0",
    "pngjs": "7.0.0",
    "ws": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.3"
  },
  "optionalDependencies": {
    "@vitest/coverage-v8": "^4.1.4"
  }
}
